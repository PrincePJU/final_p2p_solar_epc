<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    controllerName="solar.epc.projectmanagement.home.HomePage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:cssgrid="sap.ui.layout.cssgrid"
    xmlns:card="sap.f.cards"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:dnd="sap.ui.core.dnd"
    xmlns:html="http://www.w3.org/1999/xhtml"
    displayBlock="true">

    <html:style>
        /* ── Workspace Tile Base ───────────────────────────────── */
        .fioriTile {
            height: 100% !important; width: 100% !important;
            border-radius: 0.75rem !important; border: none !important;
            box-shadow: 0 1px 4px 0 rgba(0,0,0,0.10) !important;
        }
        /* Tile colours */
        .tileBlue    { background: linear-gradient(135deg, #0A6ED1, #0854A1) !important; }
        .tileOrange  { background: linear-gradient(135deg, #E9730C, #C35F08) !important; }
        .tilePurple  { background: linear-gradient(135deg, #902BF5, #7520CC) !important; }
        .tileTeal    { background: linear-gradient(135deg, #008A8A, #006666) !important; }
        .tileMagenta { background: linear-gradient(135deg, #B125CA, #8F1CA5) !important; }
        .tileGreen   { background: linear-gradient(135deg, #107E3E, #0C612F) !important; }
        /* White text/icons for coloured tiles */
        .tileBlue *, .tileOrange *, .tilePurple *,
        .tileTeal *, .tileMagenta *, .tileGreen * {
            color: #FFFFFF !important; text-shadow: none !important;
        }

        /* ── Insight / Todo Card ───────────────────────────────── */
        .insightCard {
            border-radius: 0.75rem !important; border: none !important;
            box-shadow: 0 1px 4px 0 rgba(0,0,0,0.10) !important;
            background-color: #FFFFFF !important;
        }

        /* ── App Cards (GridListItem inner content) ────────────── */
        .appCardItem {
            background-color: #FFFFFF;
            border-radius: 0.75rem;
            border: 1px solid #E5E5E5;
            height: 4.5rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .appCardItem:hover {
            box-shadow: 0 6px 16px rgba(10, 110, 209, 0.15);
            border-color: #0A6ED1;
            transform: translateY(-2px);
        }
        /* Remove default GridListItem focus ring colour bleed */
        .sapFGridListItem .sapMLIBContent { padding: 0 !important; }

        /* ── Page background ───────────────────────────────────── */
        .customPageBackground { background-color: #F4F4F6 !important; }

        /* ── Spacing helpers ───────────────────────────────────── */
        .sectionHeader  { margin-top: 1.25rem !important; margin-bottom: 0.5rem !important; }
        .denseGrid      { gap: 0.75rem !important; }

        /* ── Custom Additions for a Joyful UI ──────────────────── */
        .greetingBanner {
            background: linear-gradient(135deg, #E6F0FA 0%, #FFFFFF 100%);
            border-radius: 1rem;
            box-shadow: 0 4px 16px rgba(0,0,0,0.04);
            padding: 1.5rem 2rem;
            border: 1px solid #E5E5E5;
        }
        .insightCardContent { padding: 1.5rem; }
        .kpiValue { font-size: 2.25rem; font-weight: bold; color: #0A6ED1; line-height: 1.2; }
        .kpiLabel { color: #666666; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; }
    </html:style>

    <Page id="page" showHeader="true" title="{view>/systemName} — My Home" class="customPageBackground">

        <!-- ── Header bar ───────────────────────────────────────────────── -->
        <headerContent>
            <Button id="btnSearch" icon="sap-icon://search" tooltip="Search" type="Transparent" />
            <Button id="btnBell"   icon="sap-icon://bell"   tooltip="Notifications" type="Transparent" />
            <!-- Role switcher (demo only — replaced by XSUAA token in production) -->
            <Select id="roleSelect" selectedKey="{view>/currentRole}"
                change="onRoleChange" tooltip="Demo: Switch Role">
                <core:Item id="roleItemEngineer"    key="ENGINEER"            text="Engineer" />
                <core:Item id="roleItemSenior"      key="PROJECT_MANAGER"     text="Senior Engineer" />
                <core:Item id="roleItemProcurement" key="PROCUREMENT_OFFICER" text="Procurement Officer" />
                <core:Item id="roleItemSite"        key="SITE_ENGINEER"       text="Site Engineer" />
                <core:Item id="roleItemFinance"     key="FINANCE_OFFICER"     text="Finance Officer" />
                <core:Item id="roleItemMgmt"        key="MANAGEMENT"          text="Management" />
            </Select>
            <Button id="btnUser" icon="sap-icon://customer" text="{view>/userName}" type="Transparent" />
        </headerContent>

        <content>
            <VBox id="pageContent" class="sapUiMediumMarginBeginEnd sapUiSmallMarginTopBottom">

                <!-- ── Greeting Banner ────────────────────────────────────── -->
                <HBox id="greetingBox" alignItems="Center" class="greetingBanner sapUiMediumMarginBottom">
                    <f:Avatar id="userAvatar" src="sap-icon://customer"
                        displaySize="XL" class="sapUiMediumMarginEnd" backgroundColor="Accent6" />
                    <VBox id="greetingText">
                        <Title id="greetingTitle" text="{view>/greeting}, {view>/userName} 👋" level="H1" class="sapUiTinyMarginBottom" />
                        <Text  id="greetingRole"  text="{view>/role} | {view>/systemName}"
                            class="sapMAnnotatedText sapUiMediumFontSize" />
                    </VBox>
                </HBox>

                <!-- ── To Do list ─────────────────────────────────────────── -->
                <f:Card id="todoCard" class="sapUiMediumMarginBottom insightCard" width="100%">
                    <f:header>
                        <card:Header id="todoCardHeader" title="Action Items" subtitle="Tasks requiring your attention" statusText="{view>/todosCount} Pending" iconSrc="sap-icon://task" />
                    </f:header>
                    <f:content>
                        <List id="todoList"
                            items="{view>/todos}"
                            noDataText="🎉 All caught up! Nothing pending for your role.">
                            <StandardListItem
                                title="{view>task}"
                                description="{view>project} | {view>role}"
                                icon="{view>icon}"
                                type="Navigation"
                                press="onTodoPress"
                                info="{view>status}"
                                infoState="{view>state}" />
                        </List>
                    </f:content>
                </f:Card>

                <!-- ── Workspaces & Pages ──────────────────────────────────── -->
                <HBox id="workspaceHeader" alignItems="Center" justifyContent="SpaceBetween" class="sectionHeader">
                    <Title id="workspaceTitle" text="Workspaces &amp; Pages" level="H3" />
                    <Button id="btnEditWorkspaces" icon="{= ${view>/editMode} ? 'sap-icon://accept' : 'sap-icon://edit' }" type="{= ${view>/editMode} ? 'Emphasized' : 'Transparent' }" press="onEditPress" tooltip="Edit Pages" />
                </HBox>

                <cssgrid:CSSGrid id="workspaceGrid"
                    gridTemplateColumns="repeat(auto-fill, minmax(13rem, 1fr))"
                    gridAutoRows="9rem"
                    gridGap="0.75rem"
                    class="sapUiSmallMarginBottom denseGrid">
                    <cssgrid:dragDropConfig>
                        <dnd:DragInfo sourceAggregation="items" enabled="{view>/editMode}" />
                        <dnd:DropInfo targetAggregation="items" dropPosition="Between" drop="onDrop" enabled="{view>/editMode}" />
                    </cssgrid:dragDropConfig>

                    <!-- Insight card — visible for roles with analytics access -->
                    <f:Card id="insightCard" class="sapUiNoMargin insightCard" height="100%" visible="{view>/access/insightCard}">
                        <f:layoutData>
                            <cssgrid:GridItemLayoutData id="insightLayout" gridColumn="span 2" gridRow="span 2" />
                        </f:layoutData>
                        <f:header>
                            <card:Header id="insightCardHeader" title="Financial Health" subtitle="Aggregated Project Metrics" iconSrc="sap-icon://line-chart" />
                        </f:header>
                        <f:content>
                            <VBox class="insightCardContent" justifyContent="SpaceBetween" height="100%">
                                <HBox justifyContent="SpaceBetween" width="100%" class="sapUiSmallMarginBottom">
                                    <VBox>
                                        <Text text="YTD SPEND" class="kpiLabel" />
                                        <Text text="₹ 45.2M" class="kpiValue sapUiTinyMarginTop" />
                                    </VBox>
                                    <VBox alignItems="End">
                                        <Text text="STATUS" class="kpiLabel" />
                                        <ObjectStatus text="On Track" state="Success" icon="sap-icon://sys-enter-2" class="sapUiSmallMarginTop" />
                                    </VBox>
                                </HBox>
                                <VBox class="sapUiSmallMarginTop">
                                    <HBox justifyContent="SpaceBetween">
                                        <Text text="Budget Utilization" class="sapMAnnotatedText" />
                                        <Text text="72%" class="sapMAnnotatedText" />
                                    </HBox>
                                    <ProgressIndicator percentValue="72" displayValue="72%" showValue="false" state="Warning" height="0.75rem" class="sapUiTinyMarginTop" />
                                </VBox>
                            </VBox>
                        </f:content>
                    </f:Card>

                    <!-- MyHome — always visible -->
                    <GenericTile id="tileHome" class="fioriTile tileBlue"
                        header="MyHome" subheader="Dashboard" press="onNavPress">
                        <TileContent id="tileHomeContent">
                            <core:Icon id="tileHomeIcon" src="sap-icon://home" size="2rem" />
                        </TileContent>
                    </GenericTile>

                    <!-- Engineering & Projects -->
                    <GenericTile id="tileEngineering" class="fioriTile tileOrange"
                        header="Engineering &amp; Projects" subheader="BOQ &amp; Execution"
                        press="onNavPress" visible="{view>/access/tile_engineeringProjects}">
                        <TileContent id="tileEngineeringContent">
                            <core:Icon id="tileEngineeringIcon" src="sap-icon://project-definition-triangle" size="2rem" />
                        </TileContent>
                    </GenericTile>

                    <!-- Procurement -->
                    <GenericTile id="tileProcurement" class="fioriTile tilePurple"
                        header="Procurement" subheader="Orders &amp; Vendors"
                        press="onNavPress" visible="{view>/access/tile_procurement}">
                        <TileContent id="tileProcurementContent">
                            <core:Icon id="tileProcurementIcon" src="sap-icon://cart" size="2rem" />
                        </TileContent>
                    </GenericTile>

                    <!-- Site Operations -->
                    <GenericTile id="tileSiteOps" class="fioriTile tileTeal"
                        header="Site Operations" subheader="Receipts &amp; Damage"
                        press="onNavPress" visible="{view>/access/tile_siteOps}">
                        <TileContent id="tileSiteOpsContent">
                            <core:Icon id="tileSiteOpsIcon" src="sap-icon://shipping-status" size="2rem" />
                        </TileContent>
                    </GenericTile>

                    <!-- Vendor Rebates -->
                    <GenericTile id="tileVendorRebates" class="fioriTile tileMagenta"
                        header="Vendor Rebates" subheader="Contract Management"
                        press="onNavPress" visible="{view>/access/tile_vendorRebates}">
                        <TileContent id="tileVendorRebatesContent">
                            <core:Icon id="tileVendorRebatesIcon" src="sap-icon://waiver" size="2rem" />
                        </TileContent>
                    </GenericTile>

                    <!-- Finance Cockpit -->
                    <GenericTile id="tileFinance" class="fioriTile tileGreen"
                        header="Finance Cockpit" subheader="Invoice Validation"
                        press="onNavPress" visible="{view>/access/tile_finance}">
                        <TileContent id="tileFinanceContent">
                            <core:Icon id="tileFinanceIcon" src="sap-icon://money-bills" size="2rem" />
                        </TileContent>
                    </GenericTile>

                </cssgrid:CSSGrid>

                <!-- ── Apps ───────────────────────────────────────────────── -->
                <HBox id="appsHeader" alignItems="Center" justifyContent="SpaceBetween"
                    class="sectionHeader sapUiSmallMarginTop">
                    <Title id="appsTitle" text="Apps" level="H3" />
                    <Button id="btnEditApps" icon="{= ${view>/editMode} ? 'sap-icon://accept' : 'sap-icon://edit' }" type="{= ${view>/editMode} ? 'Emphasized' : 'Transparent' }" press="onEditPress" tooltip="Edit Apps" />
                </HBox>

                <IconTabBar id="appsTabBar" expandable="false" class="sapUiNoMarginTop">
                    <items>
                        <IconTabFilter id="tabFavorites" text="Favorites" key="fav">

                            <!-- GridList: items support type="Active" + press event -->
                            <f:GridList id="appGrid"
                                mode="None"
                                showNoData="true"
                                noDataText="No apps are available for your current role."
                                class="sapUiTinyMarginTop">
                                <f:dragDropConfig>
                                    <dnd:DragInfo sourceAggregation="items" enabled="{view>/editMode}" />
                                    <dnd:DropInfo targetAggregation="items" dropPosition="Between" drop="onDrop" enabled="{view>/editMode}" />
                                </f:dragDropConfig>
                                <f:customLayout>
                                    <cssgrid:GridBasicLayout id="appGridLayout"
                                        gridTemplateColumns="repeat(auto-fill, minmax(18rem, 1fr))"
                                        gridGap="0.75rem" />
                                </f:customLayout>

                                <!-- ── Project Service apps ──────────────────── -->
                                <f:GridListItem id="appCreateMR"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_createMR}"
                                    data:appKey="createMR" data:appLabel="Create Material Request">
                                    <HBox id="appCreateMRBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://create-form"  size="1.75rem" color="#0A6ED1" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Create Material Request" level="H5" />
                                            <Text text="Raise BOQ requirements" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <f:GridListItem id="appApproveMR"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_approveMR}"
                                    data:appKey="approveMR" data:appLabel="Approve Material Request">
                                    <HBox id="appApproveMRBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://approvals" size="1.75rem" color="#107E3E" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Approve Material Request" level="H5" />
                                            <Text text="Review &amp; authorise requests" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <!-- ── Vendor Service apps ───────────────────── -->
                                <f:GridListItem id="appManageVendors"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_manageVendors}"
                                    data:appKey="manageVendors" data:appLabel="Manage Vendors">
                                    <HBox id="appManageVendorsBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://supplier" size="1.75rem" color="#0A6ED1" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Manage Vendors" level="H5" />
                                            <Text text="Master data &amp; performance scores" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <f:GridListItem id="appCompareQuotations"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_compareQuotations}"
                                    data:appKey="compareQuotations" data:appLabel="Compare Quotations">
                                    <HBox id="appCompareQuotationsBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://compare" size="1.75rem" color="#E9730C" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Compare Quotations" level="H5" />
                                            <Text text="Evaluate bids &amp; select vendor" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <!-- ── Procurement Service apps ──────────────── -->
                                <f:GridListItem id="appCreatePO"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_createPO}"
                                    data:appKey="createPO" data:appLabel="Create Purchase Order">
                                    <HBox id="appCreatePOBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://sales-order" size="1.75rem" color="#902BF5" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Create Purchase Order" level="H5" />
                                            <Text text="Generate vendor PO" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <f:GridListItem id="appTrackDeliveries"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_trackDeliveries}"
                                    data:appKey="trackDeliveries" data:appLabel="Track Deliveries">
                                    <HBox id="appTrackDeliveriesBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://shipping-status" size="1.75rem" color="#B125CA" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Track Deliveries" level="H5" />
                                            <Text text="Monitor shipments &amp; ETA" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <!-- ── Receipt Service apps ──────────────────── -->
                                <f:GridListItem id="appPostGR"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_postGR}"
                                    data:appKey="postGR" data:appLabel="Post Goods Receipt">
                                    <HBox id="appPostGRBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://receipt" size="1.75rem" color="#008A8A" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Post Goods Receipt" level="H5" />
                                            <Text text="Verify site material delivery" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <f:GridListItem id="appReportDamage"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_reportDamage}"
                                    data:appKey="reportDamage" data:appLabel="Report Damaged Materials">
                                    <HBox id="appReportDamageBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://quality-issue" size="1.75rem" color="#D32030" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Report Damaged Materials" level="H5" />
                                            <Text text="Initiate vendor claim process" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <!-- ── Invoice Service apps ──────────────────── -->
                                <f:GridListItem id="appValidateInvoice"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_validateInvoice}"
                                    data:appKey="validateInvoice" data:appLabel="Validate Supplier Invoice">
                                    <HBox id="appValidateInvoiceBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://my-sales-order" size="1.75rem" color="#C14646" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="Validate Supplier Invoice" level="H5" />
                                            <Text text="Three-way match &amp; approve" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                                <!-- ── Dashboard Service apps ────────────────── -->
                                <f:GridListItem id="appProjectHealth"
                                    type="Active" press="onAppPress"
                                    visible="{view>/access/app_projectHealth}"
                                    data:appKey="projectHealth" data:appLabel="View Project Health">
                                    <HBox id="appProjectHealthBox" class="appCardItem sapUiSmallPadding" alignItems="Center">
                                        <core:Icon src="sap-icon://line-chart-time-axis" size="1.75rem" color="#0A6ED1" class="sapUiMediumMarginEnd" />
                                        <VBox>
                                            <Title text="View Project Health" level="H5" />
                                            <Text text="Budget &amp; procurement insights" class="sapMAnnotatedText" />
                                        </VBox>
                                    </HBox>
                                </f:GridListItem>

                            </f:GridList>
                        </IconTabFilter>

                        <IconTabFilter id="tabRecent" text="Recently Used" key="recent">
                            <Text id="recentText" text="No recently used apps." class="sapUiSmallMargin" />
                        </IconTabFilter>

                        <IconTabFilter id="tabFrequent" text="Frequently Used" key="frequent">
                            <Text id="frequentText" text="Frequent apps will appear here based on usage." class="sapUiSmallMargin" />
                        </IconTabFilter>
                    </items>
                </IconTabBar>

            </VBox>
        </content>
    </Page>
</mvc:View>
