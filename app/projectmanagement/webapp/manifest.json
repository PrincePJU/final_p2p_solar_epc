{
  "_version": "1.83.0",
  "sap.app": {
    "id": "solar.epc.projectmanagement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "5950fd3f-09a7-43fc-b949-a55b808bdf14"
    },
    "dataSources": {
      "mainService": {
        "uri": "/project/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "vendorService": {
        "uri": "/vendor/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "solar.epc.projectmanagement.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "vendorService": {
        "dataSource": "vendorService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "login/LoginPage.css"
        },
        {
          "uri": "home/HomePage.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": "",
          "name": "LoginPage",
          "target": "LoginPage"
        },
        {
          "pattern": "home",
          "name": "HomePage",
          "target": "HomePage"
        },
        {
          "pattern": "Projects:?query:",
          "name": "ProjectsList",
          "target": "ProjectsList"
        },
        {
          "pattern": "Projects({key}):?query:",
          "name": "ProjectsObjectPage",
          "target": "ProjectsObjectPage"
        },
        {
          "pattern": "ActiveProjects:?query:",
          "name": "EngineeringProjectsList",
          "target": "EngineeringProjectsList"
        },
        {
          "pattern": "ActiveProjects({key}):?query:",
          "name": "EngineerObjectPage",
          "target": "EngineerObjectPage"
        },
        {
          "pattern": "SeniorActiveProjects:?query:",
          "name": "SeniorProjectsList",
          "target": "SeniorProjectsList"
        },
        {
          "pattern": "SeniorActiveProjects({key}):?query:",
          "name": "SeniorObjectPage",
          "target": "SeniorObjectPage"
        },
        {
          "pattern": "Vendors:?query:",
          "name": "VendorList",
          "target": "VendorList"
        },
        {
          "pattern": "Vendors({key}):?query:",
          "name": "VendorObjectPage",
          "target": "VendorObjectPage"
        },
        {
          "pattern": "CompareQuotations",
          "name": "QuotationComparison",
          "target": "QuotationComparison"
        },
        {
          "pattern": "MaterialRequests:?query:",
          "name": "MRApprovalDashboard",
          "target": "MRApprovalDashboard"
        },
        {
          "pattern": "MaterialRequests({key}):?query:",
          "name": "MRApprovalDetail",
          "target": "MRApprovalDetail"
        },
        {
          "pattern": "ActiveProjects({key})/materialRequests({mrKey}):?query:",
          "name": "EngineerMRObjectPage",
          "target": "EngineerMRObjectPage"
        },
        {
          "pattern": "SeniorActiveProjects({key})/materialRequests({mrKey}):?query:",
          "name": "SeniorMRObjectPage",
          "target": "SeniorMRObjectPage"
        }
      ],
      "targets": {
        "ProjectsList": {
          "type": "Component",
          "id": "ProjectsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Projects",
              "variantManagement": "Page",
              "navigation": {
                "Projects": {
                  "detail": {
                    "route": "ProjectsObjectPage"
                  }
                }
              },
              "initialLoad": true,
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable",
                    "selectionMode": "Single",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": {
                      "column": true,
                      "sort": true,
                      "filter": true,
                      "group": true
                    }
                  },
                  "columns": {
                    "DataField::status": {
                      "importance": "High",
                      "width": "140px"
                    },
                    "DataField::projectCode": {
                      "importance": "High",
                      "width": "160px"
                    },
                    "DataField::budget": {
                      "importance": "High",
                      "width": "160px"
                    }
                  }
                }
              }
            }
          }
        },
        "ProjectsObjectPage": {
          "type": "Component",
          "id": "ProjectsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/Projects",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Facets": {
                  "sections": {
                    "BOQSection": { "visible": false },
                    "MRSection":  { "visible": false }
                  }
                }
              },
              "sectionLayout": "Tabs"
            }
          }
        },
        "EngineeringProjectsList": {
          "type": "Component",
          "id": "EngineeringProjectsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ActiveProjects",
              "variantManagement": "Page",
              "navigation": {
                "ActiveProjects": {
                  "detail": { "route": "EngineerObjectPage" }
                }
              },
              "initialLoad": true,
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Single",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true }
                  }
                }
              }
            }
          }
        },
        "EngineerObjectPage": {
          "type": "Component",
          "id": "EngineerObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ActiveProjects",
              "navigation": {
                "materialRequests": {
                  "detail": { "route": "EngineerMRObjectPage" }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::ProjectService.activateProject": { "visible": false },
                    "DataFieldForAction::ProjectService.putOnHold":        { "visible": false },
                    "DataFieldForAction::ProjectService.completeProject":  { "visible": false },
                    "DataFieldForAction::ProjectService.cancelProject":    { "visible": false }
                  }
                },
                "boqItems/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "creationMode": {
                      "name": "Inline"
                    },
                    "selectionMode": "Multi",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true, "group": true }
                  }
                },
                "materialRequests/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "enableExport": true,
                    "selectionMode": "Multi",
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true, "group": true }
                  },
                  "actions": {
                    "DataFieldForAction::ProjectService.approveRequest": { "visible": false },
                    "DataFieldForAction::ProjectService.rejectRequest":  { "visible": false },
                    "DataFieldForAction::ProjectService.closeRequest":   { "visible": false }
                  }
                }
              },
              "sectionLayout": "Tabs"
            }
          }
        },
        "SeniorProjectsList": {
          "type": "Component",
          "id": "SeniorProjectsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/SeniorActiveProjects",
              "variantManagement": "Page",
              "navigation": {
                "SeniorActiveProjects": {
                  "detail": { "route": "SeniorObjectPage" }
                }
              },
              "initialLoad": true,
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Single",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true }
                  }
                }
              }
            }
          }
        },
        "SeniorObjectPage": {
          "type": "Component",
          "id": "SeniorObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/SeniorActiveProjects",
              "navigation": {
                "materialRequests": {
                  "detail": { "route": "SeniorMRObjectPage" }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::ProjectService.activateProject": { "visible": false },
                    "DataFieldForAction::ProjectService.putOnHold":        { "visible": false },
                    "DataFieldForAction::ProjectService.completeProject":  { "visible": false },
                    "DataFieldForAction::ProjectService.cancelProject":    { "visible": false }
                  }
                },
                "boqItems/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable",
                    "selectionMode": "Multi",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true, "group": true }
                  },
                  "actions": {
                    "StandardAction::Create": { "visible": false },
                    "StandardAction::Delete": { "visible": false }
                  }
                },
                "materialRequests/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "enableExport": true,
                    "selectionMode": "Multi",
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true, "group": true }
                  },
                  "actions": {
                    "StandardAction::Create": { "visible": false },
                    "DataFieldForAction::ProjectService.submitRequest": { "visible": false }
                  }
                }
              },
              "sectionLayout": "Tabs"
            }
          }
        },
        "VendorList": {
          "type": "Component",
          "id": "VendorList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/VendorMaster",
              "model": "vendorService",
              "variantManagement": "Page",
              "navigation": {
                "VendorMaster": {
                  "detail": { "route": "VendorObjectPage" }
                }
              },
              "initialLoad": true,
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Single",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true }
                  }
                }
              }
            }
          }
        },
        "VendorObjectPage": {
          "type": "Component",
          "id": "VendorObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/VendorMaster",
              "model": "vendorService",
              "editableHeaderContent": false,
              "sectionLayout": "Tabs",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::VendorService.deactivateVendor": { "visible": true },
                    "DataFieldForAction::VendorService.activateVendor":   { "visible": true }
                  }
                }
              }
            }
          }
        },
        "MRApprovalDashboard": {
          "type": "Component",
          "id": "MRApprovalDashboard",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/MaterialRequests",
              "variantManagement": "Page",
              "initialLoad": true,
              "defaultTemplateAnnotationPath": "@com.sap.vocabularies.UI.v1.SelectionVariant#PendingApproval",
              "navigation": {
                "MaterialRequests": {
                  "detail": { "route": "MRApprovalDetail" }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Multi",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": { "column": true, "sort": true, "filter": true }
                  },
                  "actions": {
                    "StandardAction::Create": { "visible": false },
                    "StandardAction::Delete": { "visible": false }
                  }
                }
              }
            }
          }
        },
        "MRApprovalDetail": {
          "type": "Component",
          "id": "MRApprovalDetail",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/MaterialRequests",
              "editableHeaderContent": false,
              "sectionLayout": "Tabs",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::ProjectService.submitRequest": { "visible": false },
                    "DataFieldForAction::ProjectService.closeRequest":  { "visible": false }
                  }
                }
              }
            }
          }
        },
        "EngineerMRObjectPage": {
          "type": "Component",
          "id": "EngineerMRObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/ActiveProjects/materialRequests",
              "editableHeaderContent": false,
              "sectionLayout": "Tabs",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::ProjectService.approveRequest": { "visible": false },
                    "DataFieldForAction::ProjectService.rejectRequest":  { "visible": false },
                    "DataFieldForAction::ProjectService.closeRequest":   { "visible": false }
                  }
                },
                "items/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "creationMode": { "name": "Inline" },
                    "selectionMode": "Multi",
                    "enableExport": true
                  }
                }
              }
            }
          }
        },
        "SeniorMRObjectPage": {
          "type": "Component",
          "id": "SeniorMRObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/SeniorActiveProjects/materialRequests",
              "editableHeaderContent": false,
              "sectionLayout": "Tabs",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::ProjectService.submitRequest": { "visible": false },
                    "DataFieldForAction::ProjectService.closeRequest":  { "visible": false }
                  }
                },
                "items/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "None",
                    "enableExport": true
                  },
                  "actions": {
                    "StandardAction::Create": { "visible": false },
                    "StandardAction::Delete": { "visible": false }
                  }
                }
              }
            }
          }
        },
        "LoginPage": {
          "type": "View",
          "id": "LoginPage",
          "name": "solar.epc.projectmanagement.login.LoginPage",
          "viewLevel": 0
        },
        "HomePage": {
          "type": "View",
          "id": "HomePage",
          "name": "solar.epc.projectmanagement.home.HomePage",
          "viewLevel": 1
        },
        "QuotationComparison": {
          "type": "View",
          "id": "QuotationComparison",
          "name": "solar.epc.projectmanagement.vendor.QuotationComparison",
          "viewLevel": 2
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
