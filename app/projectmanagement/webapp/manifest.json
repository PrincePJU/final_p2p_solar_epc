{
  "_version": "1.83.0",
  "sap.app": {
    "id": "solar.epc.projectmanagement",
    "type": "application",
    "i18n": {
      "bundleUrl": "i18n/i18n.properties",
      "supportedLocales": ["en", ""],
      "fallbackLocale": ""
    },
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "5950fd3f-09a7-43fc-b949-a55b808bdf14"
    },
    "dataSources": {
      "mainService": {
        "uri": "/project/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "vendorService": {
        "uri": "/vendor/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "invoiceService": {
        "uri": "/invoice/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "procurementService": {
        "uri": "/procurement/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "receiptService": {
        "uri": "/receipt/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "dashboardService": {
        "uri": "/dashboard/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "solar.epc.projectmanagement.i18n.i18n",
          "supportedLocales": ["en", ""],
          "fallbackLocale": ""
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "vendorService": {
        "dataSource": "vendorService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "invoiceService": {
        "dataSource": "invoiceService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "procurementService": {
        "dataSource": "procurementService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "receiptService": {
        "dataSource": "receiptService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "dashboardService": {
        "dataSource": "dashboardService",
        "preload": false,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": false
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "login/LoginPage.css"
        },
        {
          "uri": "home/HomePage.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": "",
          "name": "LoginPage",
          "target": "LoginPage"
        },
        {
          "pattern": "home",
          "name": "HomePage",
          "target": "HomePage"
        },
        {
          "pattern": "management-overview",
          "name": "ManagementDashboard",
          "target": "ManagementDashboard"
        },
        {
          "pattern": "Projects:?query:",
          "name": "ProjectsList",
          "target": "ProjectsList"
        },
        {
          "pattern": "Projects({key}):?query:",
          "name": "ProjectsObjectPage",
          "target": "ProjectsObjectPage"
        },
        {
          "pattern": "ActiveProjects:?query:",
          "name": "EngineeringProjectsList",
          "target": "EngineeringProjectsList"
        },
        {
          "pattern": "ActiveProjects({key}):?query:",
          "name": "EngineerObjectPage",
          "target": "EngineerObjectPage"
        },
        {
          "pattern": "SeniorActiveProjects:?query:",
          "name": "SeniorProjectsList",
          "target": "SeniorProjectsList"
        },
        {
          "pattern": "SeniorActiveProjects({key}):?query:",
          "name": "SeniorObjectPage",
          "target": "SeniorObjectPage"
        },
        {
          "pattern": "Vendors:?query:",
          "name": "VendorList",
          "target": "VendorList"
        },
        {
          "pattern": "Vendors({key}):?query:",
          "name": "VendorObjectPage",
          "target": "VendorObjectPage"
        },
        {
          "pattern": "CompareQuotations",
          "name": "QuotationComparison",
          "target": "QuotationComparison"
        },
        {
          "pattern": "Invoices:?query:",
          "name": "InvoiceList",
          "target": "InvoiceList"
        },
        {
          "pattern": "Invoices({key}):?query:",
          "name": "InvoiceObjectPage",
          "target": "InvoiceObjectPage"
        },
        {
          "pattern": "ApprovedMaterialRequests:?query:",
          "name": "ProcurementMRList",
          "target": "ProcurementMRList"
        },
        {
          "pattern": "ApprovedMaterialRequests({key}):?query:",
          "name": "ProcurementMRDetail",
          "target": "ProcurementMRDetail"
        },
        {
          "pattern": "GRN:?query:",
          "name": "GRNList",
          "target": "GRNList"
        },
        {
          "pattern": "GRN({key}):?query:",
          "name": "GRNObjectPage",
          "target": "GRNObjectPage"
        },
        {
          "pattern": "Deliveries:?query:",
          "name": "DeliveryList",
          "target": "DeliveryList"
        },
        {
          "pattern": "Deliveries({key}):?query:",
          "name": "DeliveryObjectPage",
          "target": "DeliveryObjectPage"
        },
        {
          "pattern": "PurchaseOrders:?query:",
          "name": "POList",
          "target": "POList"
        },
        {
          "pattern": "PurchaseOrders({key}):?query:",
          "name": "POObjectPage",
          "target": "POObjectPage"
        },
        {
          "pattern": "MaterialRequests:?query:",
          "name": "MRApprovalDashboard",
          "target": "MRApprovalDashboard"
        },
        {
          "pattern": "MaterialRequests({key}):?query:",
          "name": "MRApprovalDetail",
          "target": "MRApprovalDetail"
        },
        {
          "pattern": "ActiveProjects({key})/materialRequests({mrKey}):?query:",
          "name": "EngineerMRObjectPage",
          "target": "EngineerMRObjectPage"
        },
        {
          "pattern": "SeniorActiveProjects({key})/materialRequests({mrKey}):?query:",
          "name": "SeniorMRObjectPage",
          "target": "SeniorMRObjectPage"
        }
      ],
      "targets": {
        "ProjectsList": {
          "type": "Component",
          "id": "ProjectsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Projects",
              "variantManagement": "Page",
              "navigation": {
                "Projects": {
                  "detail": {
                    "route": "ProjectsObjectPage"
                  }
                }
              },
              "initialLoad": true,
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable",
                    "selectionMode": "Single",
                    "enableExport": true,
                    "condensedTableLayout": false,
                    "personalization": {
                      "column": true,
                      "sort": true,
                      "filter": true,
                      "group": true
                    }
                  },
                  "columns": {
                    "DataField::status": {
                      "importance": "High",
                      "width": "140px"
                    },
                    "DataField::projectCode": {
                      "importance": "High",
                      "width": "160px"
                    },
                    "DataField::budget": {
                      "importance": "High",
                      "width": "160px"
                    }
                  }
                }
              }
            }
          }
        },
        "ProjectsObjectPage": {
          "type": "Component",
          "id": "ProjectsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/Projects",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Facets": {
                  "sections": {
                    "BOQSection": { "visible": false },
                    "MRSection":  { "visible": false }
                  }
                }
              },
              "sectionLayout": "Tabs"
            }
          }
        },
        "EngineeringProjectsList": {
