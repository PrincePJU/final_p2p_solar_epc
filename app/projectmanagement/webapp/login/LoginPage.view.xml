<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    controllerName="solar.epc.projectmanagement.login.LoginPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Shell id="loginShell" appWidthLimited="false">
        <app>
            <App id="loginApp">
                <pages>
                    <Page id="loginPage" showHeader="false" backgroundDesign="Transparent">
                        <content>
                            <FlexBox
                                id="loginOuter"
                                alignItems="Center"
                                justifyContent="Center"
                                class="loginShell">
                                <VBox id="loginCard" class="loginCard">
                                    <VBox id="brandBox" alignItems="Center" class="sapUiSmallMarginBottom">
                                        <core:Icon
                                            id="brandIcon"
                                            src="sap-icon://energy-savings-item"
                                            size="3rem"
                                            class="loginLogo sapUiSmallMarginBottom" />
                                        <Title id="brandTitle" text="SolarSage EPC" level="H2" />
                                        <Text
                                            id="brandSub"
                                            text="Enterprise Project &amp; Procurement Platform"
                                            class="loginSubtitle"
                                            textAlign="Center" />
                                    </VBox>

                                    <ToolbarSeparator id="loginDivider" class="loginDivider" />

                                    <Label id="lblUsername" text="Username" class="roleLabel" />
                                    <Input
                                        id="inputUsername"
                                        placeholder="Enter your username"
                                        value="{login>/username}"
                                        class="sapUiTinyMarginBottom" />

                                    <Label id="lblPassword" text="Password" class="roleLabel sapUiTinyMarginTop" />
                                    <Input
                                        id="inputPassword"
                                        type="Password"
                                        placeholder="Enter your password"
                                        value="{login>/password}"
                                        submit="onLoginPress"
                                        class="sapUiTinyMarginBottom" />

                                    <MessageStrip
                                        id="demoStrip"
                                        text="Demo mode - select a role to log in as."
                                        type="Information"
                                        showIcon="true"
                                        showCloseButton="false"
                                        class="sapUiTinyMarginBottom sapUiTinyMarginTop" />

                                    <Label id="loginLblRole" text="Role" class="roleLabel sapUiTinyMarginTop" />
                                    <Select id="loginRoleSelect" selectedKey="{login>/selectedRole}" width="100%">
                                        <core:Item id="loginRoleItemBDM" key="BDM" text="Business Development Manager" />
                                        <core:Item id="loginRoleItemEngineer" key="ENGINEER" text="Engineer" />
                                        <core:Item id="loginRoleItemSenior" key="PROJECT_MANAGER" text="Senior Engineer" />
                                        <core:Item id="loginRoleItemProcurement" key="PROCUREMENT_OFFICER" text="Procurement Officer" />
                                        <core:Item id="loginRoleItemSite" key="SITE_ENGINEER" text="Site Engineer" />
                                        <core:Item id="loginRoleItemFinance" key="FINANCE_OFFICER" text="Finance Officer" />
                                        <core:Item id="loginRoleItemMgmt" key="MANAGEMENT" text="Management" />
                                    </Select>

                                    <Button
                                        id="btnLogin"
                                        text="Sign In"
                                        type="Emphasized"
                                        press="onLoginPress"
                                        class="loginBtn" />

                                    <Text
                                        id="loginFooter"
                                        text="(c) 2026 SolarSage EPC. All rights reserved."
                                        class="loginSubtitle sapUiTinyMarginTop"
                                        textAlign="Center" />
                                </VBox>
                            </FlexBox>
                        </content>
                    </Page>
                </pages>
            </App>
        </app>
    </Shell>
</mvc:View>
