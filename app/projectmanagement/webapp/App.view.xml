<mvc:View
    controllerName="solar.epc.projectmanagement.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns="sap.m"
    displayBlock="true">
    <App id="app">
        <Page id="rootPage" showHeader="false" enableScrolling="false">
            <content>
                <VBox fitContainer="true" height="100%">
                    <f:ShellBar
                        id="shellBar"
                        title="SAP S/4HANA Cloud, public edition"
                        secondTitle="Procure to Pay"
                        homeIcon="sap-icon://sys-monitor"
                        showNavButton="{app>/showBackButton}"
                        navButtonPressed=".onBackPress"
                        showCopilot="true"
                        showSearch="true"
                        showNotifications="true"
                        showProductSwitcher="true">
                        <f:profile>
                            <f:Avatar initials="MP" press=".onProfilePress" />
                        </f:profile>
                    </f:ShellBar>
                    
                    <IconTabBar id="anchorBar" expandable="false" applyContentPadding="false" backgroundDesign="Transparent" class="sapUiNoMarginBottom">
                        <items>
                            <IconTabFilter text="My Home" key="home" />
                            <IconTabFilter text="Accounts Payable" key="ap" />
                            <IconTabFilter text="Inventory Processing" key="ip" />
                            <IconTabFilter text="Employee - Procurement" key="ep" />
                        </items>
                    </IconTabBar>

                    <VBox
                        visible="{app>/pageBannerVisible}"
                        class="appRouteBanner">
                        <HBox justifyContent="SpaceBetween" wrap="Wrap" class="appRouteBannerInner">
                            <VBox class="appRouteBannerCopy">
                                <Text text="{app>/pageBannerEyebrow}" class="appRouteBannerEyebrow" />
                                <Title text="{app>/pageBannerTitle}" level="H3" class="appRouteBannerTitle" />
                                <Text text="{app>/pageBannerDescription}" class="appRouteBannerText" />
                                <Text text="Vendor directory" class="appRouteBannerFieldLabel" />
                            </VBox>
                            <VBox class="appRouteBannerOrbit">
                                <Text text="Decision Canvas" class="appRouteBannerOrbitEyebrow" />
                                <Text text="Commercial + performance + vendor context" class="appRouteBannerOrbitText" />
                            </VBox>
                            <HBox wrap="Wrap" class="appRouteBannerActions">
                                <Button
                                    text="Back"
                                    icon="sap-icon://nav-back"
                                    type="Transparent"
                                    press=".onBannerBackPress"
                                    class="appRouteBannerBackBtn" />
                                <Button
                                    text="{app>/pageBannerNextText}"
                                    icon="sap-icon://navigation-right-arrow"
                                    iconFirst="false"
                                    type="Emphasized"
                                    press=".onBannerNextPress"
                                    class="appRouteBannerNextBtn" />
                            </HBox>
                        </HBox>
                    </VBox>

                    <f:FlexibleColumnLayout
                        id="fcl"
                        backgroundDesign="Solid"
                        layout="OneColumn">
                        <f:layoutData>
                            <FlexItemData growFactor="1" baseSize="0" />
                        </f:layoutData>
                    </f:FlexibleColumnLayout>
                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>
